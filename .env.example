# --- DrJhaGPT Pro : configuration ---
# Copy this file to ".env" and fill in your values. Never commit the real .env.

# ---- LLM: Groq (default) OR a self-hosted OpenAI-compatible endpoint ----
# Groq (free): get a key at https://console.groq.com/keys
GROQ_API_KEY=
# Optional 2nd key from a SEPARATE Groq account, for daily-limit failover:
# GROQ_API_KEY2=
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini free tier — a SECOND provider, not a replacement. When every Groq
# key hits its daily cap the studio keeps working here instead of failing
# mid-document. Optional: https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_MODELS=gemini-2.5-flash,gemini-2.0-flash

# Self-hosted / air-gapped (vLLM / Ollama / NVIDIA NIM). Setting LLM_BASE_URL
# selects the OpenAI-compatible path; no data leaves your network.
LLM_PROVIDER=groq                 # groq | openai
# LLM_BASE_URL=http://vllm:8000/v1
# LLM_API_KEY=
# LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

# ---- Retrieval ----
RETRIEVAL_MODE=hybrid             # dense | hybrid | hybrid_rerank
VECTOR_BACKEND=numpy             # numpy | qdrant (local)
RAG_TOP_K=4
RAG_MIN_SCORE=0.30

# ---- Phase 2 toggles ----
ENABLE_AUTH=1
ENABLE_GUARDRAILS=1
ENABLE_TRACING=1
ENABLE_MODERATION=0              # Groq Llama Guard (extra call)
USE_PRESIDIO=0                   # production-grade PII (needs presidio installed)

# ---- Studio: team features (all optional; see SUPABASE_SETUP.md) ----
# Unset = single-trainer mode. Every generator still works; the shared library
# and Admin Console are hidden and logins come from .streamlit/auth.yaml.
# SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# SUPABASE_KEY=                   # service_role key — server-side secret ONLY
DB_PREFIX=dj_                    # every table is prefixed, so a Supabase project
                                 # can be SHARED with another app without the
                                 # generic names (app_users, events) colliding.
                                 # Change only before first setup, and update the
                                 # SQL in SUPABASE_SETUP.md to match.
ADMIN_USERS=pranay               # always treated as admin (bootstrap)
AUTH_PROVIDER=local              # local | (sso, once implemented)

# Tracks a trainer belongs to, and that material is shared to.
# One per line as "CODE = Friendly Name"; the CODE is what gets stored.
# TRACKS="""
# VMW = VMware & Private Cloud
# CLD = Public Cloud
# """

# Environment label. Set to anything other than "production" to get a visible
# "test environment" banner (use it for a staging copy of the app).
APP_ENV=production

# ---- Optional integrations ----
# SUPPORT_WHATSAPP=              # digits incl. country code, shown on quota errors
# WEBSITE_POST_URL=              # lets Article Draft create a WordPress draft
# WEBSITE_POST_TOKEN=
