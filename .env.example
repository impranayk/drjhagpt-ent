# --- DrJhaGPT : configuration ---
# Copy this file to ".env" and fill in your values. Never commit the real .env.

# Groq API key (free) -> get one at https://console.groq.com/keys
GROQ_API_KEY=

# Open-source model served by Groq (default is a strong general model).
# Other options: llama-3.1-8b-instant (faster/cheaper), mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# How many knowledge snippets to retrieve from your website content per question.
RAG_TOP_K=4

# Minimum similarity (0-1) for a retrieved snippet to be considered relevant.
RAG_MIN_SCORE=0.30
