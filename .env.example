# --- DrJhaGPT Enterprise : configuration ---
# Copy this file to ".env" and fill in your values. Never commit the real .env.

# ---- LLM: Groq (default) OR a self-hosted OpenAI-compatible endpoint ----
# Groq (free): get a key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Self-hosted / air-gapped (vLLM / Ollama / NVIDIA NIM). Setting LLM_BASE_URL
# selects the OpenAI-compatible path; no data leaves your network.
LLM_PROVIDER=groq                 # groq | openai
# LLM_BASE_URL=http://vllm:8000/v1
# LLM_API_KEY=
# LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

# ---- Retrieval ----
RETRIEVAL_MODE=hybrid             # dense | hybrid | hybrid_rerank
VECTOR_BACKEND=numpy             # numpy | qdrant (local)
RAG_TOP_K=4
RAG_MIN_SCORE=0.30

# ---- Phase 2 toggles ----
ENABLE_AUTH=1
ENABLE_GUARDRAILS=1
ENABLE_TRACING=1
ENABLE_MODERATION=0              # Groq Llama Guard (extra call)
USE_PRESIDIO=0                   # production-grade PII (needs presidio installed)
